# Copy to .env and adjust. Never commit .env.
# Owner role — migrations and seeds only.
DATABASE_URL=postgresql://priora:priora_dev_only@localhost:5432/priora
# Least-privilege runtime role — the app's Pool. INSERT/SELECT-only on audit_log.
# REQUIRED in production (the app refuses to start without it outside development).
APP_DATABASE_URL=postgresql://priora_app:priora_app_dev_only@localhost:5432/priora
# Auth.js session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=
